{
  "name": "bitbucket-cloud-mcp-server",
  "version": "1.3.0",
  "description": "A Model Context Protocol server for Bitbucket Cloud repositories, pull requests, commits, and reviews.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "bitbucket-cloud-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --watch './**/*.ts' --exec 'tsx' ./src/index.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "pack:dry-run": "npm pack --dry-run"
  },
  "keywords": [
    "bitbucket",
    "bitbucket-cloud",
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "pull-requests",
    "code-review"
  ],
  "author": "Mustaqeem Tariq",
  "license": "ISC",
  "homepage": "https://github.com/mustaqeemtariq/bitbucket-cloud-mcp-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mustaqeemtariq/bitbucket-cloud-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/mustaqeemtariq/bitbucket-cloud-mcp-server/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.17.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "nodemon": "^3.1.14",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
